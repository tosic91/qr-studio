{
  "name": "qr-code-app",
  "version": "1.0.0",
  "description": "Dynamic QR Code Generator with analytics and customization",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "migrate": "knex migrate:latest --env production",
    "migrate:dev": "knex migrate:latest --env development",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "qr-code",
    "dynamic-qr",
    "generator"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "knex": "^3.2.9",
    "nanoid": "^3.3.11",
    "pg": "^8.20.0"
  }
}
